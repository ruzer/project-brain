{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "rootDir": ".",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": false
  },
  "include": [
    "agents/**/*.ts",
    "analysis/**/*.ts",
    "cli/**/*.ts",
    "core/**/*.ts",
    "governance/**/*.ts",
    "integrations/**/*.ts",
    "memory/**/*.ts",
    "orchestrator/**/*.ts",
    "shared/**/*.ts",
    "tools/**/*.ts"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}
